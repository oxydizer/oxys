# Rendered spec templates (regenerated by build.sh on every run)
.build/

# Build artifact — drop your own compiled binary here locally, don't commit it
overlay/usr/local/bin/oxys-installer
overlay/usr/local/bin/oxys-login
overlay/usr/local/bin/oxys

# On-target config-compiler payload, regenerated by build-installer-overlay.sh
# (crate source + vendored deps can be hundreds of MB — never commit)
overlay/usr/src/oxys/
overlay/root/.cargo/

# GURU overlay checkout, cloned by build-installer-overlay.sh (hundreds of MB).
# The oxys overlay next to it (overlay/var/db/repos/oxys) IS committed — it's our
# own ebuilds.
overlay/var/db/repos/guru/
