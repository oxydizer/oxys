# niri: screen-capture support (pipewire-backed screencast portal path). Matches
# oxys-installer/configs/desktop.fe2o3, which sets the screencast use flag on niri.
gui-wm/niri screencast

# Niri in QEMU needs Mesa's virgl Gallium driver. Keep this package-local even
# though make.conf also lists virgl in VIDEO_CARDS: catalyst accepted an
# official Mesa binpkg without video_cards_virgl, leaving /dev/dri present but
# no virtio_gpu_dri.so renderer in the finished ISO.
media-libs/mesa video_cards_virgl

# The Gentoo seatd ebuild installs only libseat by default. The standalone
# daemon and /etc/init.d/seatd are gated behind USE=server; the desktop config
# enables that OpenRC service, so it must be present in the live root that is
# rsync'd to the installed system.
sys-auth/seatd server

# OpenRC sessions launch PipeWire through gentoo-pipewire-launcher. Make it the
# complete desktop audio server: pipewire-pulse serves PulseAudio applications,
# while pipewire-alsa routes native ALSA applications into the same graph.
# Include the BlueZ SPA plugin so Bluetooth headsets appear as PipeWire audio
# devices rather than only being pairable through bluetoothd.
media-video/pipewire sound-server pipewire-alsa bluetooth

# Match the x86-64-v3 binhost build and integrate removable media through the
# udisks/gvfs stack already included in the desktop image.
xfce-base/thunar udisks

# Gentoo ships the USB-disk, Android/MTP, and camera backends as USE-controlled
# components of gvfs rather than separate gvfs-mtp/gvfs-gphoto2 packages.
gnome-base/gvfs udisks mtp gphoto2

# freetype<->harfbuzz have a circular dependency, so the profile leaves freetype
# built without harfbuzz by default. pango (via pangomm -> gtkmm -> pavucontrol)
# requires freetype[harfbuzz], so turn it on -- the standard resolution.
media-libs/freetype harfbuzz

# NOTE: the earlier per-package X toggles (gtk+/gtk -X, cairo/libglvnd +X,
# libepoxy) are gone. X is now on globally (make.conf + livecd/use), so the whole
# GTK/GL/*mm graph is X-consistent -- firefox-bin's gtk+3[X]/cairo[X] and the
# gtkmm C++ bindings all resolve without piecemeal overrides.
