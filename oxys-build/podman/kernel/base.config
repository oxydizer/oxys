# OxysOS base kernel config for gentoo-sources.
# This file only uses symbols available in the pinned upstream x86 Kconfig.

# Scheduler and latency.
# Use the stock mainline scheduler. The pinned gentoo-sources-7.0.14-r1 tree
# used by this build does not expose CONFIG_SCHED_CLASS_EXT, so sched-ext is
# not enabled in this kernel profile.
CONFIG_PREEMPT=y
CONFIG_PREEMPT_VOLUNTARY=n
CONFIG_PREEMPT_NONE=n
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_LOCALVERSION="-oxys"
CONFIG_LOCALVERSION_AUTO=n
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y

# Loadable module support.
# OpenZFS is shipped through sys-fs/zfs-kmod as an out-of-tree module built
# against the exact kernel release produced by this config.
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODVERSIONS=y
CONFIG_MODULE_SRCVERSION_ALL=y
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_CRYPTO_DEFLATE=y
CONFIG_ZLIB_DEFLATE=y
CONFIG_ZLIB_INFLATE=y

# Core filesystems
CONFIG_EXT4_FS=y
CONFIG_XFS_FS=y
CONFIG_BTRFS_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# Live ISO boot media (dracut dmsquash-live).
# The ISO boots the squashfs live image via dracut's dmsquash-live module,
# which depends on dracut's overlayfs module, whose check() hard-fails at
# initramfs BUILD time (require_kernel_modules overlay) when the target
# kernel has no overlayfs -- that is exactly catalyst stage2's
#   "Module 'dmsquash-live' depends on module 'overlayfs', which can't be
#    installed"
# failure. squashfs (with every codec mksquashfs might use), loop, and
# iso9660 are the rest of the live-media stack needed at boot time.
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XATTR=y
CONFIG_SQUASHFS_ZLIB=y
CONFIG_SQUASHFS_LZO=y
CONFIG_SQUASHFS_LZ4=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_ISO9660_FS=y
CONFIG_JOLIET=y
CONFIG_ZISOFS=y
# FAT for the ESP and USB install media (the installer formats/mounts these).
CONFIG_VFAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y

# Device mapper: dracut's dm module sits in dmsquash-live's dependency chain
# (the chroot-side half of this is sys-fs/lvm2 in installcd-stage1.spec).
CONFIG_MD=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_SNAPSHOT=y

# Boot-critical storage, built in (=y) so neither the live initramfs nor an
# installed system can lose its root/boot device to a missing module: AHCI
# SATA (also QEMU q35's -cdrom bus), NVMe, SCSI disk + CD-ROM, and USB
# mass storage on XHCI/EHCI controllers.
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_SR=y
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_BLK_DEV_NVME=y
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_PCI=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y

# Desktop and console input. Niri/libinput consumes /dev/input/event* through
# evdev; PS/2 keyboard/mouse support alone can make the tty appear functional
# while leaving the Wayland session with no input at all. The project QEMU
# runner also attaches explicit virtio keyboard and tablet devices.
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_VIRTIO_INPUT=y

# UEFI boot + efivars (the installer writes EFI boot entries), plus a
# firmware framebuffer handed to simpledrm (SYSFB_SIMPLEFB) so the live
# console works before/without a native DRM driver. CONFIG_FB=n below only
# drops legacy fbdev drivers; fbcon rides on DRM fbdev emulation.
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFIVAR_FS=y
CONFIG_SYSFB_SIMPLEFB=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_DRM_FBDEV_EMULATION=y

# QEMU guest support: oxys-iso/scripts/run-qemu.sh boots the ISO on q35/OVMF
# with virtio disks, NIC, and GPU. Built in (=y) because the stage2 spec's
# dracut_args pass -o qemu, so module-based virtio would not be guaranteed a
# seat in the initramfs.
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_SCSI=y
CONFIG_VIRTIO_NET=y
CONFIG_DRM_VIRTIO_GPU=y
# The QEMU runner exposes an ISA 8250 UART on its multiplexed host terminal.
# Built-in console support provides boot logs and the live recovery getty.
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=y
# Host directory sharing provided by run-qemu.sh share=PATH. Keep this built in
# so the live medium and installed system can mount the hostshare 9p tag.
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y

# Networking
CONFIG_NET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NET_NS=y
CONFIG_NET_SCH_FQ=y
CONFIG_DEFAULT_FQ=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y

# Installer/live ISO network hardware coverage.
# The ISO consumes this same kernel, so keep common wired, wireless, and USB
# NIC support broad enough for unknown install hardware. Build drivers as
# modules and let udev/kmod autoload them from device modaliases.
CONFIG_NETDEVICES=y
CONFIG_ETHERNET=y
CONFIG_NET_VENDOR_3COM=y
CONFIG_VORTEX=m
CONFIG_TYPHOON=m
CONFIG_NET_VENDOR_ADAPTEC=y
CONFIG_ADAPTEC_STARFIRE=m
CONFIG_NET_VENDOR_AGERE=y
CONFIG_ET131X=m
CONFIG_NET_VENDOR_AMD=y
CONFIG_AMD8111_ETH=m
CONFIG_PCNET32=m
CONFIG_NET_VENDOR_AQUANTIA=y
CONFIG_AQTION=m
CONFIG_NET_VENDOR_ATHEROS=y
CONFIG_ATL2=m
CONFIG_ATL1=m
CONFIG_ATL1E=m
CONFIG_ATL1C=m
CONFIG_ALX=m
CONFIG_NET_VENDOR_INTEL=y
CONFIG_E100=m
CONFIG_E1000=m
CONFIG_E1000E=m
CONFIG_IGB=m
CONFIG_IGBVF=m
CONFIG_IXGBE=m
CONFIG_IXGBEVF=m
CONFIG_I40E=m
CONFIG_IAVF=m
CONFIG_ICE=m
CONFIG_IGC=m
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_8139CP=m
CONFIG_8139TOO=m
CONFIG_R8169=m
CONFIG_NET_VENDOR_BROADCOM=y
CONFIG_B44=m
CONFIG_TIGON3=m
CONFIG_BNX2=m
CONFIG_CNIC=m
CONFIG_BNX2X=m
CONFIG_BNXT=m
CONFIG_NET_VENDOR_CHELSIO=y
CONFIG_CHELSIO_T1=m
CONFIG_CHELSIO_T3=m
CONFIG_CHELSIO_T4=m
CONFIG_CHELSIO_T4VF=m
CONFIG_NET_VENDOR_CISCO=y
CONFIG_ENIC=m
CONFIG_NET_VENDOR_DEC=y
CONFIG_NET_TULIP=m
CONFIG_DE2104X=m
CONFIG_TULIP=m
CONFIG_WINBOND_840=m
CONFIG_DM9102=m
CONFIG_NET_VENDOR_DLINK=y
CONFIG_DL2K=m
CONFIG_SUNDANCE=m
CONFIG_NET_VENDOR_EMULEX=y
CONFIG_BE2NET=m
CONFIG_JME=m
CONFIG_NET_VENDOR_MARVELL=y
CONFIG_SKGE=m
CONFIG_SKY2=m
CONFIG_NET_VENDOR_MELLANOX=y
CONFIG_MLX4_CORE=m
CONFIG_MLX4_EN=m
CONFIG_MLX5_CORE=m
CONFIG_MLX5_CORE_EN=y
CONFIG_NET_VENDOR_MICREL=y
CONFIG_KSZ884X_PCI=m
CONFIG_NET_VENDOR_MICROCHIP=y
CONFIG_LAN743X=m
CONFIG_NET_VENDOR_NATSEMI=y
CONFIG_NATSEMI=m
CONFIG_NS83820=m
CONFIG_NET_VENDOR_NVIDIA=y
CONFIG_FORCEDETH=m
CONFIG_NET_VENDOR_QLOGIC=y
CONFIG_QLA3XXX=m
CONFIG_QLCNIC=m
CONFIG_NETXEN_NIC=m
CONFIG_QED=m
CONFIG_QEDE=m
CONFIG_NET_VENDOR_SIS=y
CONFIG_SIS900=m
CONFIG_SIS190=m
CONFIG_NET_VENDOR_SOLARFLARE=y
CONFIG_SFC=m
CONFIG_SFC_FALCON=m
CONFIG_SFC_SIENA=m
CONFIG_NET_VENDOR_SMSC=y
CONFIG_EPIC100=m
CONFIG_SMSC9420=m
CONFIG_NET_VENDOR_VIA=y
CONFIG_VIA_RHINE=m
CONFIG_VIA_VELOCITY=m

# Common PHYs used behind PCI, USB, and platform NIC controllers.
CONFIG_BROADCOM_PHY=m
CONFIG_AQUANTIA_PHY=m
CONFIG_MARVELL_PHY=m
CONFIG_MARVELL_10G_PHY=m
CONFIG_MICREL_PHY=m
CONFIG_MICROCHIP_PHY=m
CONFIG_REALTEK_PHY=m
CONFIG_SMSC_PHY=m

# Virtual NICs used by the major hypervisors. Virtio stays built in above.
CONFIG_VMXNET3=m
CONFIG_HYPERV_NET=m
CONFIG_XEN_NETDEV_FRONTEND=m

# VPNs, containers, and cellular links commonly needed on an installed system.
CONFIG_TUN=m
CONFIG_VETH=m
CONFIG_WIREGUARD=m
CONFIG_PPP=m
CONFIG_PPP_ASYNC=m
CONFIG_PPP_SYNC_TTY=m
CONFIG_PPP_DEFLATE=m
CONFIG_PPP_BSDCOMP=m
CONFIG_PPPOE=m

CONFIG_WIRELESS=y
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_RFKILL=y
CONFIG_WLAN=y
CONFIG_WLAN_VENDOR_ADMTEK=y
CONFIG_ADM8211=m
CONFIG_WLAN_VENDOR_ATH=y
CONFIG_ATH5K=m
CONFIG_ATH9K=m
