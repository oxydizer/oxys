# PCIe/USB cellular modems used by ModemManager.
CONFIG_WWAN=y
CONFIG_MHI_BUS=m
CONFIG_MHI_BUS_PCI_GENERIC=m
CONFIG_MHI_NET=m
CONFIG_QCOM_BAM_DMUX=m
CONFIG_RPMSG_WWAN_CTRL=m

# CPU frequency and desktop governor
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# Graphics stack baseline
CONFIG_PCI=y
CONFIG_DRM=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_DRM_KMS_HELPER=y
# NVIDIA drivers are intentionally left out of the install media. They are
# configured after installation instead.
CONFIG_DRM_NOUVEAU=n
CONFIG_FB=n

# Memory
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=n
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_ZSWAP=y
CONFIG_ZRAM=y

# Security and sandboxing
CONFIG_SECURITY=y
CONFIG_SECURITY_LANDLOCK=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# systemd / containers / eBPF
CONFIG_CGROUPS=y
CONFIG_CGROUP_BPF=y
CONFIG_NAMESPACES=y
CONFIG_USER_NS=y
CONFIG_INOTIFY_USER=y
CONFIG_FANOTIFY=y
CONFIG_BPF_SYSCALL=y

# I/O schedulers
CONFIG_MQ_IOSCHED_KYBER=y
CONFIG_IOSCHED_BFQ=y

# Disable unused subsystems
CONFIG_STAGING=n
CONFIG_HAMRADIO=n
CONFIG_ISDN=n
CONFIG_PCMCIA=n
CONFIG_CARDBUS=n
CONFIG_MEDIA_SUPPORT=n
CONFIG_DVB_CORE=n
CONFIG_JOYSTICK=n
CONFIG_TABLET_USB_ACECAD=n
CONFIG_SOUND_OSS_CORE=n
CONFIG_SND_OSSEMUL=n
