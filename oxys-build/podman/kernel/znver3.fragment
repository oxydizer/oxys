# Zen 3 focused kernel config.
# Upstream Linux 6.19 x86 Kconfig does not expose CONFIG_MZEN3.

CONFIG_DRM_I915=n
CONFIG_DRM_AMDGPU=y
CONFIG_X86_AMD_PSTATE=y
# X86_AMD_PSTATE_DEFAULT_MODE was removed upstream (~6.10); olddefconfig was
# silently dropping it here. Select an amd-pstate mode via the `amd_pstate=`
# kernel cmdline parameter at boot instead, if one is needed.
